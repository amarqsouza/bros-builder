#!/bin/bash
#####################################################################
# Autor: Jefferson Carneiro
# Renomeie os arquivos .desktop de Debian para Br OS.
#####################################################################
set -e

####################################
# Faça a troca.
####################################
sed -i -e 's|Debian|Br OS|g' /usr/share/applications/calamares-install-debian.desktop
sed -i -e 's|^ *Icon=install-debian|Icon=/usr/share/icons/default/calamares.png|' /usr/share/applications/calamares-install-debian.desktop
